  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "canvas": "^3.0.0",
    "jsdom": "^24.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
