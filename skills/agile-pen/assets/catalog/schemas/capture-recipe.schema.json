{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://djalmajr.dev/agile-pen/capture-recipe.schema.json",
  "title": "Agile Proto capture recipe",
  "type": "object",
  "required": ["schemaVersion", "id", "source", "component", "example", "route", "selector", "viewport", "state"],
  "properties": {
    "schemaVersion": {"const": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "source": {"enum": ["shadcn", "dice-ui"]},
    "component": {"type": "string", "minLength": 1},
    "example": {"type": "string", "minLength": 1},
    "route": {"type": "string", "pattern": "^/capture/"},
    "selector": {"type": "string", "minLength": 1},
    "viewport": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": {"type": "integer", "minimum": 320},
        "height": {"type": "integer", "minimum": 240}
      },
      "additionalProperties": false
    },
    "state": {"type": "object"},
    "theme": {"enum": ["light", "dark"]},
    "direction": {"enum": ["ltr", "rtl"]}
  },
  "additionalProperties": false
}
