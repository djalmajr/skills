{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://djalmajr.dev/agile-pen/catalog-snapshot.schema.json",
  "title": "Agile Proto registry snapshot",
  "type": "object",
  "required": ["schemaVersion", "cliVersion", "source", "registry", "items", "checksum"],
  "properties": {
    "schemaVersion": {"const": 1},
    "cliVersion": {"type": "string", "minLength": 1},
    "source": {"enum": ["shadcn", "dice-ui"]},
    "registry": {"enum": ["@shadcn", "@diceui"]},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "registry", "addCommandArgument"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "type": {"type": "string", "minLength": 1},
          "registry": {"type": "string", "minLength": 1},
          "addCommandArgument": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    },
    "checksum": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  },
  "additionalProperties": false
}
