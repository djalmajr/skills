# .ai-memory.toml — per-repo ai-memory routing marker.
#
# Git-ignored BY DEFAULT (public-repo safety). For a PRIVATE team repo you MAY
# commit this so every developer gets the same routing + onboarding profile on
# `git clone`. The values below are instance config, NOT credentials.

workspace = "default"      # personal -> "default"; org repo -> its own workspace
project   = "my-project"   # defaults to the repo basename

# Optional routing/policy (defaults shown; uncomment to change — commented = no-op):
# project_strategy = "repo-root"     # collapse worktrees/subdirs to the git root (default: basename)
# drop_subagent_captures = "true"    # accept-but-don't-store THIS project's subagent captures (default: off)

# Optional: Keycloak/OIDC onboarding profile. When present, the `aim-init` skill
# reads it to wire the lifecycle hooks (device login + install-hooks) WITHOUT
# asking. The native hook only parses workspace/project, so this block is inert
# at runtime — it exists purely to make onboarding self-serve. Non-secret.
[instance]
issuer     = "https://kc.example/auth/realms/<realm>"   # OIDC realm (issuer) URL
server_url = "https://memory.example.dev/wiki"          # ai-memory URL incl. any base path
client_id  = "ai-memory-cli"                            # public device-flow client
agents     = ["claude-code"]                            # claude-code codex open-code antigravity-cli grok ...
